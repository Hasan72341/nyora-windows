<?xml version="1.0" encoding="utf-8"?>
<!--
  ============================================================================
  Nyora - Microsoft Store (MSIX) Package Manifest
  ============================================================================
  This manifest packages the Compose Multiplatform for Desktop (JVM) app as a
  full-trust MSIX. The actual application (its .exe + bundled JRE runtime\)
  produced by `./gradlew :desktopApp:createReleaseDistributable` is staged by
  scripts/build-msix.ps1 under the `app\` subfolder of the package root, so the
  Executable path below is `app\Nyora.exe`.

  >>> SUBMITTER ACTION REQUIRED <<<
  The <Identity> Name + Publisher and <Properties> PublisherDisplayName below
  are PLACEHOLDERS. Before submitting to the Microsoft Store you MUST replace
  them with the exact values Microsoft Partner Center assigns to your reserved
  app:
      Partner Center -> your app -> Product management -> Product identity
  Copy the "Package/Identity/Name", "Package/Identity/Publisher" and
  "Publisher display name" verbatim. They must match EXACTLY or the Store
  upload will be rejected.

  The Store re-signs the package on ingestion, so an EV code-signing cert is
  NOT required for Store submission. A self-signed cert (see
  scripts/New-NyoraSelfSignedCert.ps1) is only needed for local sideload
  testing of a signed .msix - and a locally-tested package must use an Identity
  whose Publisher matches that self-signed cert's Subject.

  The Version and ProcessorArchitecture attributes are patched at build time by
  scripts/build-msix.ps1 (defaults: 1.0.0.0 / x64). The literal values here are
  safe defaults; the script rewrites them per -Version / -Architecture.

  Device coverage: this is a packaged win32 (full-trust) desktop app, so it
  targets Windows.Desktop ONLY - Windows 10 (1809+) and Windows 11 on x64 and
  ARM64. It does NOT run on 32-bit x86 Windows, Xbox, HoloLens, or Windows
  phones (Nyora ships x64 + arm64 packages only).
  ============================================================================
-->
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap rescap">

  <!--
    Identity (from Partner Center -> Product management -> Product Identity for
    the reserved app "Nyora", Store ID 9MZTV9GXQ4V0):
      Name              -> Package/Identity/Name = MdHasanRaza.Nyora
      Publisher         -> Package/Identity/Publisher (full X.500 string).
                           For a Store submission this is the reserved value
                           below. For LOCAL sideload testing only, override it to
                           match the self-signed cert Subject (see
                           New-NyoraSelfSignedCert.ps1).
      Version           -> four-part a.b.c.d; patched by build-msix.ps1 from
                           -Version (1.0.0 -> 1.0.0.0). The 4th (revision) part
                           should be 0 for Store submissions.
      ProcessorArchitecture -> x64 or arm64; patched by build-msix.ps1 from
                           -Architecture (Nyora ships x64 and arm64 only).
  -->
  <Identity
      Name="MdHasanRaza.Nyora"
      Publisher="CN=C0857033-D857-4E78-A40D-3BB1C2D3558B"
      Version="2.0.0.0"
      ProcessorArchitecture="x64" />

  <!--
    Properties:
      DisplayName          -> User-visible app name. Keep "Nyora" (must match the
                              app name reserved in Partner Center).
      PublisherDisplayName -> Partner Center "Publisher display name" = Md Hasan Raza
      Logo                 -> Store/package logo, staged into assets\ by the
                              build script (generated separately from nyora.png).
  -->
  <Properties>
    <DisplayName>Nyora</DisplayName>
    <PublisherDisplayName>Md Hasan Raza</PublisherDisplayName>
    <Logo>assets\StoreLogo.png</Logo>
  </Properties>

  <!--
    Dependencies: full-trust packaged desktop app targeting the Windows.Desktop
    device family. MinVersion 10.0.17763.0 = Windows 10 1809 (matches the app's
    declared minimum OS). MaxVersionTested bumps as you validate on newer builds.
  -->
  <Dependencies>
    <TargetDeviceFamily
        Name="Windows.Desktop"
        MinVersion="10.0.17763.0"
        MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <!--
      Executable is relative to the package root. build-msix.ps1 copies the
      jpackage app-image into app\, so the app launcher resolves to app\Nyora.exe.
      EntryPoint=Windows.FullTrustApplication marks this as a packaged win32
      (desktop) app, which requires the runFullTrust capability below.

      The visual elements reference only the logos that are generated into
      assets\ (Square44x44Logo, Square150x150Logo, StoreLogo). Optional tiles
      (Wide310x150Logo, SplashScreen) are intentionally omitted so makeappx does
      not fail on missing assets; add a <uap:DefaultTile> / <uap:SplashScreen>
      here only after generating those PNGs into msix/assets/.
    -->
    <Application
        Id="Nyora"
        Executable="app\Nyora.exe"
        EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
          DisplayName="Nyora"
          Description="Nyora - manga reader and library with cloud sync and on-device OCR translation."
          BackgroundColor="transparent"
          Square150x150Logo="assets\Square150x150Logo.png"
          Square44x44Logo="assets\Square44x44Logo.png">
        <uap:DefaultTile ShortName="Nyora" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <!--
    Capabilities:
      runFullTrust  -> required for a packaged win32 desktop app (this is the
                       only way a jpackage/JVM app runs inside MSIX). Declaring
                       runFullTrust triggers Store certification review.
      internetClient -> the app fetches manga sources and performs cloud sync.
  -->
  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <Capability Name="internetClient" />
  </Capabilities>

</Package>
